<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- EAN-13 internal sequence: prefix 200, 9 numeric digits, check digit computed at runtime -->
    <record id="seq_barcode_ean13_internal" model="ir.sequence">
        <field name="name">Dukaku Internal EAN-13</field>
        <field name="code">dukaku.barcode.ean13</field>
        <field name="prefix"></field>
        <field name="suffix"></field>
        <field name="padding">9</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Code128 internal sequence: DK-{seq} -->
    <record id="seq_barcode_code128_internal" model="ir.sequence">
        <field name="name">Dukaku Internal Code128</field>
        <field name="code">dukaku.barcode.code128</field>
        <field name="prefix">DK-</field>
        <field name="suffix"></field>
        <field name="padding">6</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
