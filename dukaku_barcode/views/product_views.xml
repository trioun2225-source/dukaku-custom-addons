<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Batch backfill: callable from the product list Action menu -->
    <record id="action_server_assign_missing_barcodes" model="ir.actions.server">
        <field name="name">Assign Missing Barcodes</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_type">action</field>
        <field name="state">code</field>
        <field name="code">action = model.action_assign_missing_barcodes()</field>
    </record>

    <!-- Add barcode_symbology field to product form.
         Inherits from product_template_only_form_view because that is the view
         that actually inserts the barcode field (after categ_id). The base
         product_template_form_view does not contain barcode directly. -->
    <record id="view_product_template_form_barcode" model="ir.ui.view">
        <field name="name">product.template.form.barcode</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <field name="barcode" position="after">
                <field name="barcode_symbology" string="Symbology"
                    invisible="product_variant_count &gt; 1"/>
            </field>
        </field>
    </record>
</odoo>
