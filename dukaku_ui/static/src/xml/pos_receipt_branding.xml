<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="dukaku_ui.PosReceiptBranding"
       t-inherit="point_of_sale.OrderReceipt"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('footer-powered-by')]" position="replace">
            <div class="pos-receipt-order-data text-center pt-3 footer-powered-by">
                <span>Powered by <b>Dukaku</b></span>
            </div>
        </xpath>
    </t>

</templates>
